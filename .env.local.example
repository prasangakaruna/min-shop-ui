# Mint E-commerce API (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# NextAuth (admin panel). AUTH_SECRET is REQUIRED — without it /api/auth/session returns 500.
# Generate one: openssl rand -base64 32
AUTH_SECRET=Iad9/rZEcgzHMdKS3UkSNMxMTr1nWm2+g5E6HEF4iV0=
NEXTAUTH_URL=http://localhost:3000

# Keycloak (match Mint e-commerce-api docs: client e.g. mint-ecommerce)
# In Keycloak, add redirect URI exactly: http://localhost:3000/api/auth/callback/keycloak
# If client is Public: leave KEYCLOAK_CLIENT_SECRET empty. If Confidential: set the secret.
KEYCLOAK_CLIENT_ID=mint-ecommerce
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ISSUER=http://localhost:9091/realms/mint
